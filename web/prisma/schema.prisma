generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Setting {
  key       String @id
  value     String // encrypted for sensitive values
  updatedAt DateTime @updatedAt
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String   @default("")
  objective   String   @default("")
  status      String   @default("draft") // draft | in_progress | completed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  turks           Turk[]
  memoryEntries   MemoryEntry[]
  investorProject InvestorProject?
}

model Turk {
  id           String   @id @default(uuid())
  name         String
  type         String   @default("testing-agent")
  status       String   @default("stopped") // stopped | starting | running | paused | error
  containerId  String?
  targetUrl    String
  instructions String
  ollamaModel  String   @default("llama3.1:8b")
  modelSource  String   @default("local") // "local" or "cloud"
  role         String   @default("")
  avatar       String   @default("turk-1.png")
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  credentials   TurkCredential[]
  messages      Message[]
  taskRuns      TaskRun[]
  memoryEntries MemoryEntry[]
}

model CredentialGroup {
  id        String   @id @default(uuid())
  name      String // e.g., "Client 1 Login"
  createdAt DateTime @default(now())

  fields CredentialField[]
  turks  TurkCredential[]
}

model CredentialField {
  id       String          @id @default(uuid())
  groupId  String
  group    CredentialGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  key      String // e.g., "username", "password"
  value    String // AES-256-GCM encrypted
  isSecret Boolean         @default(false)
}

model TurkCredential {
  turkId  String
  turk    Turk            @relation(fields: [turkId], references: [id], onDelete: Cascade)
  groupId String
  group   CredentialGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([turkId, groupId])
}

model Message {
  id        String   @id @default(uuid())
  turkId    String
  turk      Turk     @relation(fields: [turkId], references: [id], onDelete: Cascade)
  role      String // user | agent | system
  content   String
  metadata  Json?
  createdAt DateTime @default(now())
}

model TaskRun {
  id          String    @id @default(uuid())
  turkId      String
  turk        Turk      @relation(fields: [turkId], references: [id], onDelete: Cascade)
  status      String    @default("running") // running | completed | failed
  summary     String?
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  steps TaskStep[]
}

model TaskStep {
  id         String   @id @default(uuid())
  runId      String
  run        TaskRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  action     String // navigate, click, fill, screenshot, assert
  target     String?
  result     String?
  screenshot String? // base64
  createdAt  DateTime @default(now())
}

model MemoryEntry {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  turkId    String?
  turk      Turk?    @relation(fields: [turkId], references: [id], onDelete: SetNull)
  category  String
  title     String
  content   String
  sourceUrl String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([turkId])
  @@index([projectId, category])
}

model InvestorProject {
  id          String    @id @default(uuid())
  projectId   String    @unique
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ticker      String
  companyName String    @default("")
  exchange    String    @default("")
  lastRunAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([ticker])
}
