# Database
# Use localhost for local dev, 'db' for docker compose
DATABASE_URL=postgresql://turk:turk@db:5432/turk

# Encryption key for credentials (setup.sh generates this automatically)
# Manual: openssl rand -hex 32
ENCRYPTION_KEY=your-256-bit-hex-key-here

# Ollama (must have a model with tool-calling support, e.g. llama3.1:8b)
# llama3 does NOT support tools — use llama3.1:8b or newer
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Docker socket path
DOCKER_SOCKET=/var/run/docker.sock

# WebSocket URL for agent containers to reach the web server
# Docker compose (production): ws://web:3124/api/ws
# Local dev (default):         ws://host.docker.internal:3124/api/ws
WS_URL=ws://web:3124/api/ws
