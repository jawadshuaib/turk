# Database
# Use localhost for local dev, 'db' for docker compose
DATABASE_URL=postgresql://turk:turk@localhost:5432/turk

# Encryption key for credentials (setup.sh generates this automatically)
# Manual: openssl rand -hex 32
ENCRYPTION_KEY=your-256-bit-hex-key-here

# Ollama local (must have a model with tool-calling support, e.g. llama3.1:8b)
# llama3 does NOT support tools — use llama3.1:8b or newer
# Use localhost for local dev; containers reach Ollama via host.docker.internal automatically
OLLAMA_BASE_URL=http://localhost:11434

# Ollama Cloud API key (optional — enables cloud model selection in the UI)
# You can also set this from the UI at Turks -> New Turk -> Ollama Cloud tab
# Get your key at: https://ollama.com/settings/keys
OLLAMA_API_KEY=

# Docker socket path
DOCKER_SOCKET=/var/run/docker.sock

# WebSocket URL for agent containers to reach the web server
# Containers use host.docker.internal to reach the host machine
WS_URL=ws://host.docker.internal:3124/api/ws
